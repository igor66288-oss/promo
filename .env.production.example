# PostgreSQL password (придумай сильный)
POSTGRES_PASSWORD=change_me_strong_password

# JWT secret (сгенерируй: openssl rand -hex 32)
JWT_SECRET=change_me_jwt_secret

# IP сервера — замени на реальный
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP/api

# Omise (пока оставь пустыми для demo-режима)
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=
